---
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
[%- if has_goreleaser %]
  workflow_dispatch:
    inputs:
      bump_type:
        type: choice
        description: "Version bump type"
        default: auto
        options: [auto, patch, minor, major]
[%- endif %]

permissions: {}

jobs:
  hk:
    uses: hugoh/go-tools/.github/workflows/go-hk.yml@[[ _copier_conf.vcs_ref_hash ]]
    permissions:
      contents: read

  goci:
    uses: hugoh/go-tools/.github/workflows/go-ci.yml@[[ _copier_conf.vcs_ref_hash ]]
    permissions:
      contents: read

[%- if has_pages %]

  pages:
    needs: [hk, goci]
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    uses: hugoh/go-tools/.github/workflows/go-pages.yml@[[ _copier_conf.vcs_ref_hash ]]
    permissions:
      contents: read
      pages: write
      id-token: write
    with:
      pages_dir: "[[ pages_dir ]]"
[%- endif %]

[%- if has_goreleaser %]

  release:
    needs: [hk, goci]
    uses: hugoh/go-tools/.github/workflows/go-release.yml@[[ _copier_conf.vcs_ref_hash ]]
    permissions:
      contents: write
    with:
      bump_type: ${{ inputs.bump_type || 'auto' }}
    secrets:
      gh_token: ${{ secrets.GITHUB_TOKEN }}
      tap_github_token: ${{ secrets.TAP_GITHUB_TOKEN }}
[%- endif %]
