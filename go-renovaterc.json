{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "customManagers:githubActionsVersions",
    "github>kachick/renovate-config-dprint#1.3.0",
    "github>hugoh/hk-config//renovate.json",
    ":automergeLinters",
    ":automergeMinor",
    ":automergeDigest",
    "schedule:monthly"
  ],
  "minimumReleaseAge": "7 days",
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true,
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Go dependencies"
    },
    {
      "matchUpdateTypes": ["major"],
      "groupName": "Major updates",
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["hugoh/go-tools"],
      "enabled": false
    },
    {
      "matchManagers": ["copier"],
      "matchPackageNames": ["https://github.com/hugoh/go-tools.git"],
      "minimumReleaseAge": null,
      "schedule": ["at any time"],
      "automerge": true
    },
    {
      "description": "mise.ci.toml is NOT Copier-managed (only repos that commit it directly, e.g. for CI-only tools like jj) — let Renovate bump it normally.",
      "matchManagers": ["mise"],
      "matchFileNames": ["mise.ci.toml"],
      "enabled": true
    }
  ],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"]
}
