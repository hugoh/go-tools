{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "customManagers:githubActionsVersions",
    "github>kachick/renovate-config-dprint#1.3.0",
    ":automergeLinters",
    ":automergeMinor",
    ":automergeDigest",
    "schedule:monthly"
  ],
  "minimumReleaseAge": "7 days",
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true,
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Go dependencies"
    },
    {
      "matchUpdateTypes": ["major"],
      "groupName": "Major updates",
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["hugoh/go-tools"],
      "enabled": false
    },
    {
      // Renovate can't resolve Copier's gh: shorthand for git-tags
      // tracked at https://github.com/renovatebot/renovate/issues/39938
      "matchManagers": ["copier"],
      "matchPackageNames": ["gh:hugoh/go-tools"],
      "packageName": "https://github.com/hugoh/go-tools.git",
      "ignoreScripts": false,
      "schedule": ["at any time"],
      "automerge": true
    }
  ],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"]
}
