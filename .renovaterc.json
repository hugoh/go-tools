{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>hugoh/go-tools:go-renovaterc"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump the hugoh/hk-config Pkl package pin in the Copier template's hk.pkl.jinja (not caught by hk-config's own .pkl-only customManager)",
      "managerFilePatterns": ["/^template/hk\\.pkl\\.jinja$/"],
      "matchStrings": [
        "package://github\\.com/hugoh/hk-config/releases/download/v[^/]+/hk-config@(?<currentValue>[^#]+)#"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "hugoh/hk-config",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver",
      "autoReplaceStringTemplate": "package://github.com/hugoh/hk-config/releases/download/v{{{newValue}}}/hk-config@{{{newValue}}}#"
    },
    {
      "customType": "regex",
      "description": "Bump the jdx/hk pin in the Copier template's hk.pkl.jinja (not caught by hk-config's own .pkl-only customManager)",
      "managerFilePatterns": ["/^template/hk\\.pkl\\.jinja$/"],
      "matchStrings": [
        "package://github\\.com/jdx/hk/releases/download/v[^/]+/hk@(?<currentValue>[^#]+)#"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "jdx/hk",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "description": "These 3 reusable workflows are uses:-pinned by commit hash via copier update in every consumer repo — a bump here only reaches consumers once go-tools cuts a new tag, so force fix (not chore) to make cocogitto's `cog bump --auto` release it. go-tools' own ci.yml is excluded: it's never consumed externally, so its own action bumps don't need a release.",
      "matchManagers": ["github-actions"],
      "matchFileNames": ["go-hk.yml", "go-ci.yml", "go-release.yml"],
      "semanticCommitType": "fix"
    },
    {
      "description": "Same reasoning as above: template/mise.toml.jinja's tool pins only reach consumers via a new go-tools tag.",
      "matchManagers": ["mise"],
      "matchFileNames": ["template/mise.toml.jinja"],
      "semanticCommitType": "fix"
    },
    {
      "description": "Same reasoning as above: template/hk.pkl.jinja's hk-config/jdx-hk pins only reach consumers via a new go-tools tag.",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["template/hk.pkl.jinja"],
      "semanticCommitType": "fix"
    },
    {
      "matchManagers": ["pip_requirements"],
      "matchPackageNames": ["pytest"],
      "groupName": "pytest (test infra)"
    }
  ],
  "mise": {
    "managerFilePatterns": [
      "**/{,.}mise{,.*}.toml",
      "**/{,.}mise/config{,.*}.toml",
      "**/.config/mise{,.*}.toml",
      "**/.config/mise/{mise,config}{,.*}.toml",
      "**/.config/mise/conf.d/*.toml",
      "**/.rtx{,.*}.toml",
      "/^template/mise\\.toml\\.jinja$/"
    ]
  }
}
