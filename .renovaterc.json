{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>hugoh/go-tools:go-renovaterc"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "semanticCommitType": "fix"
    },
    {
      "matchManagers": ["pep723", "pip_requirements"],
      "matchPackageNames": ["tomlkit"],
      "groupName": "tomlkit (merge-mise-tools + its tests)"
    }
  ],
  "mise": {
    "managerFilePatterns": ["/^template/_tools_list\\.toml\\.jinja$/"]
  },
  "pep723": {
    "managerFilePatterns": ["/^template/_tasks/merge_mise_tools\\.py$/"]
  }
}
