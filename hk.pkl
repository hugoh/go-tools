amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

local Common = new Group {
  steps {
    ["actionlint"] = Builtins.actionlint
    ["pinact"] = Builtins.pinact
    ["conflicts"] = Builtins.check_merge_conflict
    ["trailing-ws"] = Builtins.trailing_whitespace
    ["line-endings"] = Builtins.mixed_line_ending
    ["newlines"] = Builtins.newlines
    ["case-conflict"] = Builtins.check_case_conflict
    ["large-files"] = Builtins.check_added_large_files
    ["executables"] = Builtins.check_executables_have_shebangs
    ["symlinks"] = Builtins.check_symlinks
    ["gitleaks"] = Builtins.gitleaks
    ["ghalint"] = Builtins.ghalint_workflow
    ["markdown"] = Builtins.rumdl
    ["dprint"] = Builtins.dprint
    ["zizmor"] = Builtins.zizmor
    ["typos"] = Builtins.typos
    ["mise"] = Builtins.mise
  }
}

local linters = new Mapping<String, Step> {
  ...Common.steps
  ["shellcheck-dev-tasks"] = {
    glob = List("mise-tasks/*")
  }
  ["shellharden-dev-tasks"] = {
    glob = List("mise-tasks/*")
  }
  ["ruff"] = (Builtins.ruff)
  ["ruff-format"] = (Builtins.ruff_format)
  ["ty"] = (Builtins.ty) {
    check = "uv venv --quiet --clear .cache/ty-venv && uv pip install --quiet --python .cache/ty-venv -r test/requirements-merge-mise-tools.txt -r test/requirements-render-check.txt -r test/requirements-migrate-dev-watch.txt && uvx --with ty==0.0.57 ty check --python .cache/ty-venv --extra-search-path template/_tasks --extra-search-path _migrations {{files}}"
  }
  ["merge-mise-tools-test"] = {
    glob = List("test/test_merge_mise_tools.py", "template/_tasks/merge_mise_tools.py")
    check = "uv run --with-requirements test/requirements-merge-mise-tools.txt pytest test/test_merge_mise_tools.py"
  }
  ["migrate-dev-watch-test"] = {
    glob = List("test/test_migrate_dev_watch.py", "_migrations/migrate_dev_watch.py")
    check = "uv run --with-requirements test/requirements-migrate-dev-watch.txt pytest test/test_migrate_dev_watch.py"
  }
  ["render-check"] = {
    check = "mise run render-check"
  }
  ["renovate-config-validator"] = {
    glob = List(".renovaterc.json", "go-renovaterc.json")
    check = "renovate-config-validator --strict --no-global {{files}}"
  }
}

hooks {
  ["pre-commit"] {
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
