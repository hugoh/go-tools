amends "package://github.com/jdx/hk/releases/download/v1.52.0/hk@1.52.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.52.0/hk@1.52.0#/Builtins.pkl"
import "package://github.com/hugoh/hk-config/releases/download/v1.2.0/hk-config@1.2.0#/base.pkl" as Base

min_hk_version = Base.min_hk_version

local linters = new Mapping<String, Step> {
  ...Base.base
  // Deliberately scoped to just mise-tasks/* glob, not the builtins'
  // default match_any (which now also matches any shebang-detected shell
  // script by type, e.g. template/mise-tasks/* — the copier template's own
  // scripts, checked separately via render-check, not here).
  ["shellcheck_dev_tasks"] = (Builtins.shellcheck) {
    match_any = List((FileSelector) { glob = List("mise-tasks/*") })
  }
  ["shellharden_dev_tasks"] = (Builtins.shellharden) {
    glob = List("mise-tasks/*")
  }
  ["shfmt_dev_tasks"] = (Builtins.shfmt) {
    match_any = List((FileSelector) { glob = List("mise-tasks/*") })
  }
  ...Base.python
  ["ty"] = (Builtins.ty) {
    check = "uv venv --quiet --clear .cache/ty-venv && uv pip install --quiet --python .cache/ty-venv -r test/requirements-render-check.txt && uvx --with ty==0.0.57 ty check --python .cache/ty-venv {{files}}"
  }
  ["render_check"] = {
    check = "mise run render-check"
    profiles = List("ci")
  }
  ["renovate_config_validator"] = {
    glob = List(".renovaterc.json", "go-renovaterc.json")
    check = "renovate-config-validator --strict --no-global {{files}}"
  }
  ["conventional_commit"] {
    check = "cog check --from-latest-tag"
  }
}

hooks {
  ["pre-commit"] {
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
  ["commit-msg"] {
    steps = new Mapping<String, Step> {
      ["cocogitto_commit_msg"] = Builtins.cocogitto_commit_msg
    }
  }
}
