#!/usr/bin/env bash
#MISE description="Set a secret (read from stdin) on every repo listed in consumers.txt"
#USAGE arg "<name>" help="Secret name, e.g. TEMPLATE_UPDATE_TOKEN"
set -euo pipefail

root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
# shellcheck disable=SC2154 # usage_name is injected by mise from the USAGE spec above
name="${usage_name}"

value=$(cat)

while IFS= read -r repo; do
  [ -z "$repo" ] && continue
  echo "Setting ${name} on ${repo}..."
  echo "$value" | gh secret set "$name" --repo "$repo"
done < "$root/consumers.txt"

echo "Done."
