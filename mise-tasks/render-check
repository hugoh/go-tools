#!/usr/bin/env python3
# fmt: off
#MISE description="Render the Copier template against fixtures and validate the output"
# fmt: on

import glob
import os
import shutil
import subprocess
import sys
import tempfile
import threading
import time
from concurrent.futures import ThreadPoolExecutor, as_completed
from dataclasses import dataclass
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent

# hk validate evaluates hk.pkl via pkl, which reads/writes a shared package
# cache (~/.pkl/cache) that isn't safe under concurrent access (observed:
# intermittent, differing pkl parse errors across parallel tmpdirs, even
# with each tmpdir given its own HK_CACHE_DIR). Serialize just this step.
HK_LOCK = threading.Lock()

# Serializes stdout writes so a per-job summary line and its (optional)
# full failure log print as one atomic block, never interleaved with
# another thread's completion.
PRINT_LOCK = threading.Lock()


@dataclass
class Result:
    label: str
    ok: bool
    log: str


def run(cmd, cwd=None, env=None):
    proc = subprocess.run(cmd, cwd=cwd, env=env, capture_output=True, text=True)
    return proc.returncode == 0, proc.stdout + proc.stderr


def report(phase, index, total, label, ok, elapsed, log=""):
    status = "ok" if ok else "FAIL"
    with PRINT_LOCK:
        print(
            f"[{phase} {index}/{total}] {status}: {label} ({elapsed:.1f}s)", flush=True
        )
        if log:
            print(log, flush=True)


def render_one(label, data_file, tmpdir):
    tmpdir.mkdir()
    cmd = [
        "copier",
        "copy",
        "--trust",
        "--vcs-ref=HEAD",
        "--defaults",
        "-d",
        f"project_name={label}",
    ]
    if data_file is not None:
        cmd += ["--data-file", str(data_file)]
    cmd += [str(ROOT), str(tmpdir)]

    ok, log = run(cmd)
    if not ok:
        return Result(label, False, f"FAIL ({label}): copier render failed\n{log}")
    return Result(label, True, "")


def validate_one(tmpdir):
    answers = tmpdir / ".copier-answers.yml"
    label = tmpdir.name
    for line in answers.read_text().splitlines():
        if line.startswith("project_name:"):
            label = line.split(":", 1)[1].strip()
            break

    lines = [f"--- validating: {label} ---"]

    def fail(stage, output):
        lines.append(f"FAIL ({label}): {stage}")
        lines.append(output)
        return Result(label, False, "\n".join(lines))

    shellcheck_targets = glob.glob(str(tmpdir / "mise-tasks" / "*"))
    ok, log = run(["shellcheck", *shellcheck_targets])
    if not ok:
        return fail("shellcheck", log)

    workflow_targets = glob.glob(str(tmpdir / ".github" / "workflows" / "*.yml"))
    ok, log = run(["actionlint", *workflow_targets])
    if not ok:
        return fail("actionlint", log)

    ok, log = run(["dprint", "check"], cwd=tmpdir)
    if not ok:
        return fail("dprint check", log)

    with HK_LOCK:
        ok, log = run(["hk", "validate"], cwd=tmpdir)
    if not ok:
        return fail("hk validate (hk.pkl)", log)

    if (tmpdir / ".goreleaser.yml").exists():
        ok, log = run(["git", "init", "-q"], cwd=tmpdir)
        if ok:
            ok, log = run(
                [
                    "git",
                    "remote",
                    "add",
                    "origin",
                    f"https://github.com/hugoh/{label}.git",
                ],
                cwd=tmpdir,
            )
        if ok:
            env = {**os.environ, "TAP_GITHUB_TOKEN": "x"}
            ok, log = run(["goreleaser", "check"], cwd=tmpdir, env=env)
        if not ok:
            return fail("goreleaser check", log)

    lines.append(f"ok: {label}")
    return Result(label, True, "\n".join(lines))


def main():
    rootdir = Path(tempfile.mkdtemp())
    fail = False

    fixtures = sorted((ROOT / "test" / "fixtures").glob("*.yml"))
    render_jobs = [(f.stem, f, rootdir / f.stem) for f in fixtures]
    render_jobs.append(("defaults", None, rootdir / "defaults"))

    # Phase 1: render all fixtures in parallel (copier is I/O bound)
    total_render = len(render_jobs)
    print(f"--- render: {total_render} fixtures ---", flush=True)
    tmpdirs = []
    completed = 0
    with ThreadPoolExecutor() as pool:
        starts = {}
        futures = {}
        for job in render_jobs:
            future = pool.submit(render_one, *job)
            starts[future] = time.monotonic()
            futures[future] = job
        for future in as_completed(futures):
            label, _, tmpdir = futures[future]
            result = future.result()
            elapsed = time.monotonic() - starts[future]
            completed += 1
            report(
                "render",
                completed,
                total_render,
                label,
                result.ok,
                elapsed,
                result.log if not result.ok else "",
            )
            if not result.ok:
                fail = True
            else:
                tmpdirs.append(tmpdir)

    # Phase 2: validate each rendered output in parallel; each tmpdir is
    # self-contained (own dir, own git init) so runs don't interfere.
    total_validate = len(tmpdirs)
    print(f"--- validate: {total_validate} renders ---", flush=True)
    completed = 0
    with ThreadPoolExecutor() as pool:
        starts = {}
        futures = {}
        for tmpdir in tmpdirs:
            future = pool.submit(validate_one, tmpdir)
            starts[future] = time.monotonic()
            futures[future] = tmpdir
        for future in as_completed(futures):
            result = future.result()
            elapsed = time.monotonic() - starts[future]
            completed += 1
            report(
                "validate",
                completed,
                total_validate,
                result.label,
                result.ok,
                elapsed,
                result.log if not result.ok else "",
            )
            if not result.ok:
                fail = True

    shutil.rmtree(rootdir)
    return 1 if fail else 0


if __name__ == "__main__":
    sys.exit(main())
