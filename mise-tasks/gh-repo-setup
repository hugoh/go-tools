#!/usr/bin/env bash
#MISE description="One-time GitHub repo setup: branch protection (PR + hk/goci[/release] required, no direct pushes), auto-merge, and delete-branch-on-merge"
#USAGE arg "<repo>" help="owner/repo to configure (e.g. hugoh/hrd)"
#USAGE flag "--branch <branch>" help="Branch to protect" default="main"
set -euo pipefail

# shellcheck disable=SC2154 # usage_repo/usage_branch are injected by mise from the USAGE spec above
repo="${usage_repo}"
branch="${usage_branch:-main}"

contexts=("hk / hk" "goci / goci")
if gh api "repos/${repo}/contents/.goreleaser.yml" >/dev/null 2>&1; then
  contexts+=("release / release")
fi

echo "Configuring branch protection for ${repo}@${branch} (required: ${contexts[*]}; PRs required; no direct pushes, including admins)..."

contexts_json=$(printf '%s\n' "${contexts[@]}" | jq -R . | jq -s .)

gh api "repos/${repo}/branches/${branch}/protection" \
  --method PUT \
  -H "Accept: application/vnd.github+json" \
  --input - <<EOF
{
  "required_status_checks": {
    "strict": true,
    "contexts": ${contexts_json}
  },
  "enforce_admins": true,
  "required_pull_request_reviews": {
    "required_approving_review_count": 0
  },
  "restrictions": null
}
EOF

echo "Enabling auto-merge and delete-branch-on-merge on ${repo}..."
gh repo edit "${repo}" --enable-auto-merge --delete-branch-on-merge

echo "Done."
